{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 410,
  "height": 250,

  "data": {
    "url": "https://raw.githubusercontent.com/gxtan/FIT2179-DV2/main/data/sec1_data.csv"
  },

  "transform": [
    {
      "filter": "datum.variable == 'median'"
    }
  ],

  "mark": {
    "type": "line",
    "point": true
  },

  "encoding": {
    "x": {
      "field": "date",
      "type": "ordinal",
      "title": "Year"
    },

    "y": {
      "field": "income",
      "type": "quantitative",
      "title": "Median Income (RM)"
    },

    "color": {
      "field": "state",
      "type": "nominal",
      "title": "State"
    },

    "tooltip": [
      {
        "field": "state",
        "type": "nominal"
      },
      {
        "field": "date",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "income",
        "type": "quantitative",
        "title": "Income"
      }
    ]
  },

  "config": {
    "view": {
      "stroke": null
    },

    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 14
    },

    "legend": {
      "titleFontSize": 13,
      "labelFontSize": 11
    }
  }
}