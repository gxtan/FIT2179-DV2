{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "description": "2024 Waffle Chart for B40, M40, and T20",

  "data": {
    "url": "../data/sec3_data.csv"
  },

  "transform": [
    {
      "filter": "datum.variable == 'median'"
    },

    {
      "filter": "datum.date == 2024"
    },

    {
      "calculate": "datum.percentile <= 40 ? 'B40' : datum.percentile <= 80 ? 'M40' : 'T20'",
      "as": "group"
    },

    {
      "calculate": "(datum.percentile - 1) % 10",
      "as": "x"
    },

    {
      "calculate": "floor((datum.percentile - 1) / 10)",
      "as": "y"
    }
  ],

  "width": 320,
  "height": 320,

  "mark": {
    "type": "square",
    "filled": true,
    "size": 1000,
    "stroke": "white",
    "strokeWidth": 1
  },

  "encoding": {
    "x": {
      "field": "x",
      "type": "ordinal",
      "axis": null,
      "scale": {
        "paddingInner": 0,
        "paddingOuter": 0
      }
    },

    "y": {
      "field": "y",
      "type": "ordinal",
      "sort": "descending",
      "axis": null,
      "scale": {
        "paddingInner": 0,
        "paddingOuter": 0
      }
    },

    "color": {
      "field": "group",
      "type": "nominal",
      "scale": {
        "domain": ["T20", "M40", "B40"],
        "range": ["#d73027", "#f46d43", "#fee08b"]
      },
      "legend": {
        "title": "Income Group",
        "orient": "bottom"
      }
    },

    "tooltip": [
      {
        "field": "percentile",
        "title": "Percentile"
      },
      {
        "field": "income",
        "title": "Income"
      },
      {
        "field": "group",
        "title": "Category"
      }
    ]
  },

  "config": {
    "view": {
      "stroke": null
    },

    "background": "white"
  }
}