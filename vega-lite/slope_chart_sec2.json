{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Monthly Household Income to Percentile Distribution",

  "width": 410,
  "height": 250,

  "data": {
    "url": "https://raw.githubusercontent.com/gxtan/FIT2179-DV2/main/data/sec2_slope_data.csv"
  },

  "transform": [
    {
      "filter": "datum.variable == 'median' && (datum.date == 2019 || datum.date == 2024)"
    }
  ],

  "mark": {
    "type": "line",
    "point": true
  },

  "encoding": {
    "x": {
      "field": "date",
      "type": "ordinal",
      "title": "Year"
    },

    "y": {
      "field": "income",
      "type": "quantitative",
      "title": "Median Income (RM)"
    },

    "color": {
      "field": "state",
      "type": "nominal",
      "legend": null
    },

    "tooltip": [
      { "field": "state", "type": "nominal" },
      { "field": "date", "type": "ordinal" },
      { "field": "income", "type": "quantitative" }
    ]
  },

  "config": {
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 14
    },

    "view": {
      "stroke": null
    }
  }
}